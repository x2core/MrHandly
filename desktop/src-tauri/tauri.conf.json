{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oikos",
  "version": "0.0.0",
  "identifier": "dev.oikos.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Oikos",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
